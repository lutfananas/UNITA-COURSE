// Prisma schema for UNTAG Learn - MOOC Platform
// Pilot: Fakultas Ekonomi, course: Interview Skills for Beginners

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         String        @default("STUDENT") // STUDENT | INSTRUCTOR | ADMIN
  avatar       String?
  bio          String?
  headline     String? // e.g. "Mahasiswa FE UNTANG"
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  enrollments  Enrollment[]
  progress     Progress[]
  reviews      Review[]
  quizzes      QuizAttempt[]
  certificates Certificate[]
  instructed   Course[]      @relation("InstructorCourses")
}

model Category {
  id    String   @id @default(cuid())
  name  String   @unique
  slug  String   @unique
  icon  String?
  courses Course[]
}

model Course {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String
  shortDesc     String?
  thumbnail     String?
  previewVideo  String?
  category      Category?     @relation(fields: [categoryId], references: [id])
  categoryId    String?
  level         String        @default("BEGINNER") // BEGINNER | INTERMEDIATE | ADVANCED
  language      String        @default("id")
  durationMin   Int           @default(0) // total minutes
  price         Int           @default(0) // 0 = free
  premium       Boolean       @default(false)
  rating        Float         @default(0)
  reviewCount   Int           @default(0)
  enrollCount   Int           @default(0)
  published     Boolean       @default(true)
  whatYouLearn  String? // newline separated
  requirements  String? // newline separated
  tags          String? // comma separated
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  instructorId  String
  instructor    User          @relation("InstructorCourses", fields: [instructorId], references: [id])
  modules       Module[]
  enrollments   Enrollment[]
  reviews       Review[]
  certificates  Certificate[]
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int      @default(0)
  lessons     Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  contentMd   String? // markdown text content
  videoUrl    String? // optional youtube/vimeo embed
  durationMin Int      @default(0)
  order       Int      @default(0)
  preview     Boolean  @default(false) // free preview lesson
  quizId      String? // optional quiz attached to lesson
  progress    Progress[]

  @@index([moduleId])
}

model Enrollment {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt   DateTime  @default(now())
  completedAt  DateTime?
  progressPct  Float     @default(0)
  lastAccessed DateTime? @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  lastPosSec  Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   String
  score     Int      // 0-100
  passed    Boolean
  answers   String   // JSON string
  createdAt DateTime @default(now())

  @@index([userId])
}

model Certificate {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificateNo String  @unique
  issuedAt     DateTime @default(now())

  @@unique([userId, courseId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}
